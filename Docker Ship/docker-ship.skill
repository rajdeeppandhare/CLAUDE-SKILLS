tests/
test/
coverage/
.nyc_output
.pytest_cache
jest.config.*

# Editor/OS
.DS_Store
Thumbs.db
.idea
.vscode
*.swp

# Docker files themselves
Dockerfile*
docker-compose*
.dockerignore

# Documentation
README.md
README-DOCKER.md
docs/

# CI/CD
.github
.gitlab-ci.yml
.circleci
```

