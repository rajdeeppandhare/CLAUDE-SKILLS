```
# Version control
.git
.gitignore

# Dependencies (rebuilt in container)
node_modules
vendor
__pycache__
*.pyc
.venv
venv

# Build outputs
dist
build
.next
out
target

# Environment files (never bake secrets into image)
.env
.env.*
!.env.example

# Dev/test tooling
*.test.*
